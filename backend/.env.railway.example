# ── Noah AI Backend — Railway Environment Variables ──────────────────────────
# Copy these into your Railway service → Variables tab.
# Values marked (required) will crash the server if missing.

# ── Brain mode ────────────────────────────────────────────────────────────────
NOAH_BRAIN_MODE=hermes

# ── LLM provider (OpenRouter recommended for Railway) ─────────────────────────
# Get a key at https://openrouter.ai → API Keys
NOAH_HERMES_PROVIDER=openrouter
NOAH_HERMES_MODEL=openai/gpt-4.1-mini
AI_INTEGRATIONS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_INTEGRATIONS_OPENROUTER_API_KEY=sk-or-...          # (required)

# ── Firebase (required for auth + Firestore memories) ────────────────────────
# Paste the full contents of your Firebase service account JSON as one line.
FIREBASE_GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}  # (required)

# ── OpenAI (used by classic brain mode + some tools) ─────────────────────────
OPENAI_API_KEY=sk-...                                  # (required)

# ── Deepgram (speech-to-text transcription) ───────────────────────────────────
DEEPGRAM_API_KEY=...                                   # (required)

# ── Pinecone (vector memory search) ───────────────────────────────────────────
PINECONE_API_KEY=...                                   # (optional — disables semantic search if absent)

# ── Redis (session caching) ───────────────────────────────────────────────────
REDIS_DB_HOST=...                                      # (optional)
REDIS_DB_PASSWORD=...                                  # (optional)

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_KEY=...                                          # (optional — protects admin endpoints)

# ── After deploying, note your Railway public URL ─────────────────────────────
# Add this to your ~/.noahrc on Mac so Noah Desktop connects to it:
#
#   {
#     "backendUrl": "https://YOUR-APP.railway.app"
#   }
